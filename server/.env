PORT=5000
MONGODB_URI=mongodb://localhost:27017/cryptovision
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=supersecretjwtkey123!cryptovision

# Google OAuth Configuration
GOOGLE_CLIENT_ID=placeholder_client_id
GOOGLE_CLIENT_SECRET=placeholder_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# SMTP / Email Configuration (Mailtrap, SendGrid, etc.)
# If left blank, emails will fall back to printing verification/reset links directly to the console logs.
SMTP_HOST=
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@cryptovision.ai
FROM_NAME=CryptoVision

# Frontend URL
FRONTEND_URL=http://localhost:5173
